{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tagme/container",
  "version": "1.0.0",
  "title": "コンテナー",
  "category": "layout",
  "icon": "layout",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "maxWidth": {
      "type": "string",
      "default": "1000px"
    },
    "padding": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "tagme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "description": "コンテンツをラップし、最大幅や余白を制御するコンテナーブロックです。"
}