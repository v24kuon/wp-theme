{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tagme/frame",
  "version": "1.0.0",
  "title": "フレーム",
  "category": "layout",
  "icon": "layout",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "aspectRatio": {
      "type": "string",
      "default": "16/9"
    },
    "switchRatio": {
      "type": "boolean",
      "default": false
    }
  },
  "textdomain": "tagme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "description": "画像やメディアを特定の縦横比で切り抜いて表示するレイアウトブロックです。"
}