{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tagme/switcher",
  "version": "1.0.0",
  "title": "スイッチャー",
  "category": "layout",
  "icon": "layout",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "threshold": {
      "type": "string",
      "default": "40rem"
    },
    "isReverse": {
      "type": "boolean",
      "default": false
    },
    "alignItems": {
      "type": "string",
      "default": "stretch"
    },
    "stairs": {
      "type": "boolean",
      "default": false
    }
  },
  "textdomain": "tagme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "description": "指定した幅（閾値）を境に、水平・垂直レイアウトを切り替えるブロックです。"
}