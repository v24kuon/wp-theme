{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tagme/responsive-image",
  "version": "1.0.0",
  "title": "レスポンシブ画像",
  "category": "media",
  "icon": "format-image",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "background": true,
      "text": true
    }
  },
  "attributes": {
    "imageUrl": {
      "type": "string"
    },
    "alt": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "tagme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "description": "レスポンシブ対応の画像を表示するブロックです。"
}