{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tagme/with-sidebar-divided",
  "version": "1.0.0",
  "title": "サイドバー (区切りあり)",
  "category": "layout",
  "icon": "layout",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "sidebarSide": {
      "type": "string",
      "default": "left"
    },
    "isReverse": {
      "type": "boolean",
      "default": false
    },
    "sidebarWidth": {
      "type": "string",
      "default": "auto"
    },
    "mainMinWidth": {
      "type": "string",
      "default": "50%"
    },
    "alignItems": {
      "type": "string",
      "default": "stretch"
    },
    "alignContent": {
      "type": "string",
      "default": "stretch"
    },
    "padding": {
      "type": "string",
      "default": "1rem"
    },
    "tagName": {
      "type": "string",
      "default": "div"
    }
  },
  "textdomain": "tagme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "description": "メインコンテンツとサイドバーの間に区切り線を持つレイアウトブロックです。"
}
