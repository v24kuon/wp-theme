{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tagme/accordion",
  "version": "1.0.0",
  "title": "アコーディオン",
  "category": "layout",
  "icon": "layout",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "useLabel": {
      "type": "boolean",
      "default": true
    },
    "summaryText": {
      "type": "string",
      "source": "html",
      "selector": "summary",
      "default": "アコーディオンを開く"
    },
    "mark": {
      "type": "string",
      "default": "plus"
    },
    "defaultOpen": {
      "type": "boolean",
      "default": false
    },
    "useQuestionLabel": {
      "type": "boolean",
      "default": false
    },
    "questionWidth": {
      "type": "string",
      "default": ""
    },
    "useAnswerLabel": {
      "type": "boolean",
      "default": false
    },
    "answerWidth": {
      "type": "string",
      "default": ""
    },
    "padding": {
      "type": "string",
      "default": "1rem"
    }
  },
  "textdomain": "tagme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "description": "アコーディオン形式でコンテンツを開閉するブロックです。"
}
