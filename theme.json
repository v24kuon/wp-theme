{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "60ch",
			"wideSize": "80ch"
		},
		"custom": {
			"ratio": "1.333",
			"s-5": "calc(var(--wp--custom--s-4) / var(--wp--custom--ratio))",
			"s-4": "calc(var(--wp--custom--s-3) / var(--wp--custom--ratio))",
			"s-3": "calc(var(--wp--custom--s-2) / var(--wp--custom--ratio))",
			"s-2": "calc(var(--wp--custom--s-1) / var(--wp--custom--ratio))",
			"s-1": "calc(var(--wp--custom--s0) / var(--wp--custom--ratio))",
			"s0": "1rem",
			"s1": "calc(var(--wp--custom--s0) * var(--wp--custom--ratio))",
			"s2": "calc(var(--wp--custom--s1) * var(--wp--custom--ratio))",
			"s3": "calc(var(--wp--custom--s2) * var(--wp--custom--ratio))",
			"s4": "calc(var(--wp--custom--s3) * var(--wp--custom--ratio))",
			"s5": "calc(var(--wp--custom--s4) * var(--wp--custom--ratio))",
			"color-bg": "#fff",
			"color-text": "#222",
			"color-link": "#0056b3",
			"color-link-hover": "#003d82",
			"color-border": "#d1d5db"
		},
		"typography": {
			"fluid": {
				"minFontSize": "14px",
				"maxFontSize": "48px"
			},
			"fontSizes": [
				{
					"slug": "small",
					"size": "var(--wp--custom--s-1)",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "var(--wp--custom--s0)",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "var(--wp--custom--s1)",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "var(--wp--custom--s2)",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "var(--wp--custom--s3)",
					"name": "Extra Extra Large"
				}
			]
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"name": "Small",
					"size": "var(--wp--custom--s-1)",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "var(--wp--custom--s0)",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "var(--wp--custom--s1)",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"size": "var(--wp--custom--s2)",
					"slug": "x-large"
				}
			],
			"units": [ "rem", "em", "vw", "vh" ]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--custom--color-bg)",
			"text": "var(--wp--custom--color-text)"
		},
		"spacing": {
			"blockGap": "var(--wp--custom--s1)",
			"padding": {
				"top": "var(--wp--custom--s2)",
				"right": "var(--wp--custom--s1)",
				"bottom": "var(--wp--custom--s2)",
				"left": "var(--wp--custom--s1)"
			}
		},
		"typography": {
			"lineHeight": "1.7",
			"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "700"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--custom--s4)",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--custom--s3)",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--custom--s2)",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--custom--s1)",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--custom--color-link)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--custom--color-link)",
					"text": "#ffffff"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "0.5rem",
						"bottom": "0.5rem",
						"left": "1rem",
						"right": "1rem"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"css": "& .wp-block-navigation__responsive-container { background: var(--wp--custom--color-bg); padding: var(--wp--custom--s2); }\n& .current-menu-item > a { font-weight: bold; text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 4px; }"
			}
		}
	}
}
