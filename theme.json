{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1000px"
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "size": "clamp(6px, 1vw, 10px)",
          "slug": "10",
          "name": "10px"
        },
        {
          "size": "clamp(12px, 2vw, 20px)",
          "slug": "20",
          "name": "20px"
        },
        {
          "size": "clamp(18px, 3vw, 30px)",
          "slug": "30",
          "name": "30px"
        },
        {
          "size": "clamp(24px, 4vw, 40px)",
          "slug": "40",
          "name": "40px"
        },
        {
          "size": "clamp(30px, 5vw, 50px)",
          "slug": "50",
          "name": "50px"
        },
        {
          "size": "clamp(36px, 6vw, 60px)",
          "slug": "60",
          "name": "60px"
        },
        {
          "size": "clamp(42px, 7vw, 70px)",
          "slug": "70",
          "name": "70px"
        }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "typography": {
      "defaultFontSizes": false,
      "textColumns": true,
      "writingMode": true,
      "fluid": true,
      "fontSizes": [
        {
          "size": "clamp(12px, 0.32vw + 10.8px, 13.6px)",
          "fluid": false,
          "slug": "small",
          "name": "Small"
        },
        {
          "size": "clamp(13.5px, 0.4vw + 12px, 16px)",
          "fluid": false,
          "slug": "normal",
          "name": "Normal"
        },
        {
          "size": "clamp(15px, 0.56vw + 13.4px, 19.2px)",
          "fluid": false,
          "slug": "medium",
          "name": "Medium"
        },
        {
          "size": "clamp(17px, 0.64vw + 14.6px, 22.4px)",
          "fluid": false,
          "slug": "large",
          "name": "Large"
        },
        {
          "size": "clamp(20px, 0.8vw + 17px, 28.8px)",
          "fluid": false,
          "slug": "x-large",
          "name": "Extra Large"
        },
        {
          "size": "clamp(26px, 1.04vw + 22.1px, 35.2px)",
          "fluid": false,
          "slug": "xx-large",
          "name": "2X Large"
        }
      ],
      "fontFamilies": [
        {
          "slug": "system-font",
          "name": "System Font",
          "fontFamily": "'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif"
        },
        {
          "slug": "mincho-font",
          "name": "Mincho font",
          "fontFamily": "'Times New Roman', 'YuMincho', 'Hiragino Mincho ProN', 'Yu Mincho', 'MS PMincho', serif"
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontSize": "var(--wp--preset--font-size--normal)",
      "fontFamily": "var(--wp--preset--font-family--system-font)"
    },
    "elements": {
      "link": {
        "typography": {
          "textDecoration": "none"
        }
      }
    }
  }
}
